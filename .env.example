# Copie este arquivo para .env quando for executar o projeto localmente.

# Ambiente da aplicacao: development, test ou production.
APP_ENV=development

# Caminho do banco local que sera usado nas proximas fases.
DATABASE_URL=sqlite:///data/processed/catalog.db

# Provedor/modelo LLM planejado para a extracao semantica.
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1-mini

# Chave de API real deve ficar apenas no .env local.
LLM_API_KEY=

# Intervalo planejado para varredura de fontes de RI, em horas.
INGESTION_INTERVAL_HOURS=24
